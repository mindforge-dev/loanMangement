# S3 Storage (MinIO locally, AWS S3 in production)
AWS_S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=loan-contracts
